# Copy this file to .env on each local computer and fill local-only values.
# Do not commit real secrets, private key paths, passwords, or production URLs.

OPENAI_API_KEY=

MARGINS_DEPLOY_HOST=
MARGINS_DEPLOY_USER=
MARGINS_DEPLOY_DIR=/opt/margins
MARGINS_SERVICE_MANAGER=systemd
MARGINS_DEPLOY_SSH_KEY=
MARGINS_DEPLOY_HEALTH_URL=
MARGINS_RELEASE_RETAIN_COUNT=5

MARGINS_BOOK_SEARCH_PROVIDER=google
MARGINS_BOOK_SEARCH_AI_FALLBACK_ENABLED=false
GOOGLE_BOOKS_API_KEY=
KAKAO_REST_API_KEY=

MARGINS_SINGLE_USER_USERNAME=
MARGINS_SINGLE_USER_DISPLAY_NAME=
MARGINS_SINGLE_USER_PASSWORD=

MARGINS_E2E_USERNAME=
MARGINS_E2E_PASSWORD=
